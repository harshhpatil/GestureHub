# GestureHub Backend Environment Configuration
# Copy this to .env and fill in your values

PORT=3001
NODE_ENV=development

# JWT Secret — change this in production!
JWT_SECRET=gesturehub-secret-change-in-production
JWT_EXPIRES_IN=7d

# SQLite database path
DB_PATH=./gesturehub.db

# CORS origin (React dev server)
CORS_ORIGIN=http://localhost:5173

# ESP32 WebSocket connection (leave empty if no physical device)
ESP32_HOST=
ESP32_PORT=81
ESP32_WS_PATH=/ws

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
